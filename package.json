{
  "name": "umstutorial",
  "private": true,
  "type": "module",
  "scripts": {
    "sync:umsme": "scripts/sync-umsme.sh --https",
    "sync:gdrive": "node scripts/sync-gdrive.js",
    "sync:github": "node scripts/sync-github.js",
    "sync": "npm run sync:umsme && npm run sync:gdrive && npm run sync:github",
    "build": "node build.js",
    "serve": "npx --yes http-server dist -p 8000 -c-1",
    "dev": "npm run sync && npm run build && npm run serve"
  },
  "dependencies": {
    "markdown-it": "^14.1.0",
    "turndown": "^7.2.4"
  }
}
